# --- Model ---
# Eğittiğiniz best.pt dosyasının yolu (backend/ klasörüne göre)
MODEL_PATH=models\Hazir_Model.pt
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# --- Video kaynağı ---
# USB webcam için 0 (bonus). Lokal video için dosya yolu (ör. sample.mp4).
# Boş bırakılırsa sistem başlangıçta video oynatmaz, panel'den yükleme yapana kadar bekler.
VIDEO_SOURCE=
INFERENCE_FPS=10

# --- Veritabanı ---
DB_PATH=detections.db

# --- Alarm (varsayılan kapalı, panelden açılır) ---
ALARM_ENABLED=false

# --- KRİTİK DÜZELTME ---
# 'Human Diver' artık yeni modelinde olmadığı için varsayılan alarmı 'shark' veya 'fish' yapıyoruz
ALARM_CLASS=shark

# --- CORS ---
# Panelin origin'i (ör. http://localhost:3000). Geliştirmede * bırakılabilir.
CORS_ORIGINS=*